# Quiver Quantitative
QUIVER_API_TOKEN=
# Required for API requests (browser-style CSRF token from Quiver session)
QUIVER_CSRF_TOKEN=

# SendGrid (Web API — Bearer token for v3/mail/send)
SENDGRID_API_KEY=
SENDER_EMAIL=
# Comma-separated list of recipients
RECIPIENT_EMAILS=
# Optional: comma-separated CC / BCC (omitted in API if empty)
CC_EMAILS=
BCC_EMAILS=

# Daily digest (UTC): main cron sends at most one digest per UTC day after this hour.
DAILY_DIGEST_HOUR_UTC=8
# If you use a second Railway service with: python politician_tracker.py --digest
# set this to 1 on the frequent-check service to avoid two digest emails the same day.
SKIP_DIGEST_IN_MAIN_CRON=
